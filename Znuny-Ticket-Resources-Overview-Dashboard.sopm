<?xml version="1.0" encoding="utf-8" ?>
<otrs_package version="1.0">
    <Name>Znuny-Ticket-Resources-Overview-Dashboard</Name>
    <Version>7.0.2</Version>
    <Framework>7.3.x</Framework>
    <Framework>7.4.x</Framework>
    <Framework>7.5.x</Framework>
    <Vendor>vadikonline1</Vendor>
    <URL>https://github.com/vadikonline1/Znuny-Ticket-Resources-Overview-Dashboard/</URL>
    <License>GNU GENERAL PUBLIC LICENSE Version 3, 29 June 2007</License>
    <Description Lang="en">Dashboard to Display Resources (Ticket Owner) Per Ticket States.</Description>
    <ChangeLog Version="7.0.2" Date="2024-03-29 09:00:00 +0800">Add option to display based on StateType or StateName in system configuration.</ChangeLog>
    <Filelist>
        <File Permission="660" Location="Kernel/Config/Files/XML/ZZZTicketResourcesOverview.xml"/>
        <File Permission="660" Location="Kernel/Output/HTML/Dashboard/TicketResourcesOverview.pm"/>
        <File Permission="660" Location="Kernel/Output/HTML/Templates/Standard/AgentDashboardTicketResourcesOverview.tt"/>
    </Filelist>
    <IntroInstall Lang="en" Title="Install Information" Type="pre"><![CDATA[
        <br/>
        <b>WELCOME</b>
        <br/>
