        You are about to install the package Znuny-Ticket-Resources-Overview-Dashboard. Check <a href='https://github.com/vadikonline1/Znuny-Ticket-Resources-Overview-Dashboard/' target='_blank'>README</a><br/>
        <br/><br/>
        ((enjoy))<br/>
        <br/>
    ]]></IntroInstall>
    <IntroUpgrade Lang="en" Title="Upgrade Information" Type="pre"><![CDATA[
        <br/>
        Changelog<br/>
        7.0.2 - Add option to display based on StateType or StateName in system configuration.<br/><br/><br/>
        <b>IMPORTANT! If you are updating from an older version and made changes in system configuration, please reset the system configuration first before upgrade.</b>
        <br/><br/>
        ((enjoy))<br/>
        <br/>
    ]]></IntroUpgrade>
</otrs_package>